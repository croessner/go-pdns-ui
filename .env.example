# Server
GO_PDNS_UI_LISTEN_ADDRESS=:8080
GO_PDNS_UI_LOG_LEVEL=INFO
# Restrict login to OIDC only (requires OIDC to be configured).
GO_PDNS_UI_AUTH_OIDC_ONLY=false
# Force HTTP mode even when requests arrive via TLS/proxy.
# Useful for local/dev setups where HTTPS handling should be disabled explicitly.
GO_PDNS_UI_FORCE_INSECURE_HTTP=false
# Optional: restrict selectable RR types in UI forms (comma/space separated).
# Example: A,AAAA,CNAME,MX,NS,TXT,SRV,PTR,SOA,CAA,TLSA
GO_PDNS_UI_AVAILABLE_RECORD_TYPES=A,AAAA,CNAME,MX,NS,TXT,SRV,PTR,SOA,CAA,TLSA

# Access control / persistence
# Values:
# - off: disable company-based access control (default)
# - company: enforce company-based access control and persist in SQL database
GO_PDNS_UI_AUTHZ_MODE=off
GO_PDNS_UI_DATABASE_URL=
GO_PDNS_UI_DB_MAX_OPEN_CONNS=10
GO_PDNS_UI_DB_MAX_IDLE_CONNS=5
GO_PDNS_UI_DB_CONN_MAX_LIFETIME_SECONDS=300
# OIDC principal provisioning in authz mode "company":
# - true (default): unknown OIDC users are auto-created
# - false: only pre-created OIDC users are allowed to sign in
GO_PDNS_UI_AUTHZ_OIDC_AUTO_CREATE=true

# Local login
GO_PDNS_UI_USERNAME=admin
GO_PDNS_UI_PASSWORD=admin

# OIDC (optional)
# Enable by setting discovery URL, client ID, client secret and redirect URL.
# Discovery URL must be the full endpoint including /.well-known/openid-configuration
# If GO_PDNS_UI_OIDC_INTROSPECTION_URL is empty, introspection_endpoint from discovery is used.
GO_PDNS_UI_OIDC_DISCOVERY_URL=
GO_PDNS_UI_OIDC_ISSUER_URL=
GO_PDNS_UI_OIDC_INTROSPECTION_URL=
GO_PDNS_UI_OIDC_INTROSPECTION_AUTH_METHOD=client_secret_basic
GO_PDNS_UI_OIDC_INSECURE_SKIP_VERIFY=false
GO_PDNS_UI_OIDC_CLIENT_ID=
GO_PDNS_UI_OIDC_CLIENT_SECRET=
GO_PDNS_UI_OIDC_REDIRECT_URL=http://localhost:8080/auth/oidc/callback
GO_PDNS_UI_OIDC_SCOPES=openid profile email groups
GO_PDNS_UI_OIDC_ADMIN_GROUP=admin
GO_PDNS_UI_OIDC_USER_GROUP=user
# Unmatched OIDC groups fall back to role "viewer" (read-only).

# PowerDNS API (optional)
# Enable by setting API URL and API key.
GO_PDNS_API_URL=
GO_PDNS_API_KEY=
GO_PDNS_SERVER_ID=localhost
GO_PDNS_HTTP_TIMEOUT_SECONDS=10
